# ==================================================
# CONFIGURACIÓN DE PRODUCCIÓN - Sistema de Inventario
# ==================================================
#
# IMPORTANTE: Este archivo contiene configuraciones de producción.
# NO USAR EN DESARROLLO. Copiar a .env y ajustar valores reales.
#
# SEGURIDAD:
# - Generar SECRET_KEY único: openssl rand -hex 32
# - Restringir CORS_ORIGINS a dominios específicos
# - Usar PostgreSQL o MySQL en lugar de SQLite
# - Configurar HTTPS en producción
# - Habilitar rate limiting y otras medidas de seguridad
#

# ==================================================
# BASE DE DATOS - PostgreSQL (RECOMENDADO PARA PRODUCCIÓN)
# ==================================================
# Formato: postgresql://usuario:contraseña@host:puerto/nombre_db
# Ejemplo: DATABASE_URL=postgresql://inventario_user:SecurePass123@localhost:5432/inventario_prod
DATABASE_URL=postgresql://usuario:contraseña@localhost:5432/inventario

# ==================================================
# SEGURIDAD Y AUTENTICACIÓN
# ==================================================

# Clave secreta para JWT (DEBE SER ÚNICA Y SEGURA)
# Generar con: openssl rand -hex 32
SECRET_KEY=CAMBIAR_ESTA_CLAVE_POR_UNA_GENERADA_ALEATORIAMENTE_32_BYTES

# Algoritmo de encriptación JWT
ALGORITHM=HS256

# Tiempo de expiración de tokens JWT (en minutos)
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ==================================================
# CORS - Orígenes Permitidos
# ==================================================
# En producción, especificar SOLO los dominios autorizados
# Ejemplo: CORS_ORIGINS=["https://inventario.miempresa.com", "https://admin.miempresa.com"]
CORS_ORIGINS=["https://tu-dominio-frontend.com"]

# Hosts permitidos por FastAPI/TrustedHostMiddleware
# Ejemplo: ALLOWED_HOSTS=["api.tu-dominio.com", "inventario.miempresa.com"]
ALLOWED_HOSTS=["api.tu-dominio.com"]

# ==================================================
# MODO DE APLICACIÓN
# ==================================================
# false para producción (desactiva logs detallados y debugging)
DEBUG=false

# Nombre de la aplicación
APP_NAME=Sistema de Inventario Multi-Ubicación

# Entorno (development, staging, production)
ENVIRONMENT=production

# ==================================================
# API Y NETWORKING
# ==================================================
# Host y puerto del servidor
API_HOST=0.0.0.0
API_PORT=8000

# URL base de la API (para links en emails, notificaciones, etc.)
API_BASE_URL=https://api.tu-dominio.com

# ==================================================
# LOGGING
# ==================================================
# Nivel de logging (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Directorio para archivos de log
LOG_DIR=/var/log/inventario

# Habilitar logging a archivos
ENABLE_FILE_LOGGING=true

# Formato de logs (text o json - json recomendado para producción)
LOG_FORMAT=json

# ==================================================
# RATE LIMITING (RECOMENDADO)
# ==================================================
# Límite de requests por minuto por IP
RATE_LIMIT_PER_MINUTE=100

# Límite de intentos de login por hora
LOGIN_ATTEMPTS_LIMIT=5

# Tiempo de bloqueo tras exceder límite (en minutos)
LOGIN_BLOCK_TIME=15

# ==================================================
# BACKUPS AUTOMÁTICOS
# ==================================================
# Habilitar backups automáticos de base de datos
ENABLE_AUTO_BACKUP=true

# Directorio para backups
BACKUP_DIR=/var/backups/inventario

# Frecuencia de backup (diaria)
BACKUP_SCHEDULE=daily

# Número de backups a conservar
BACKUP_RETENTION_DAYS=30

# ==================================================
# EMAIL (NOTIFICACIONES)
# ==================================================
# Servidor SMTP para envío de emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu-email@empresa.com
SMTP_PASSWORD=tu-contraseña-app
SMTP_FROM=noreply@tu-dominio.com

# Habilitar TLS
SMTP_TLS=true

# ==================================================
# WHATSAPP (OPCIONAL - INTEGRACION N8N)
# ==================================================
# URL de webhook de N8N para WhatsApp
N8N_WEBHOOK_URL=https://n8n.tu-dominio.com/webhook/whatsapp

# Token de autenticación para N8N
N8N_AUTH_TOKEN=tu-token-secreto

# ==================================================
# OPENAI (FUNCIONALIDADES DE IA)
# ==================================================
# Clave API de OpenAI (para bots conversacionales y análisis)
OPENAI_API_KEY=sk-tu-clave-api-de-openai

# Modelo a usar (gpt-4, gpt-4o, gpt-3.5-turbo)
OPENAI_MODEL=gpt-4o

# Temperatura para respuestas de IA (0.0 - 1.0)
OPENAI_TEMPERATURE=0.7

# ==================================================
# MONITOREO Y APM (OPCIONAL)
# ==================================================
# Sentry DSN para tracking de errores
SENTRY_DSN=https://tu-sentry-dsn@sentry.io/proyecto

# New Relic License Key (si se usa)
NEW_RELIC_LICENSE_KEY=tu-licencia-new-relic

# ==================================================
# REDIS (OPCIONAL - PARA CACHÉ Y RATE LIMITING)
# ==================================================
# URL de Redis
REDIS_URL=redis://localhost:6379/0

# Tiempo de vida de caché (en segundos)
CACHE_TTL=3600

# ==================================================
# CONFIGURACIÓN DE PRODUCCIÓN ADICIONAL
# ==================================================
# Número de workers de Uvicorn (ajustar según CPU disponible)
WORKERS=4

# Timeout de requests (en segundos)
REQUEST_TIMEOUT=30

# Tamaño máximo de archivo de upload (en MB)
MAX_UPLOAD_SIZE_MB=10

# ==================================================
# FEATURES FLAGS
# ==================================================
# Habilitar funcionalidades específicas
ENABLE_AI_FEATURES=true
ENABLE_TRADE_IN=true
ENABLE_FINANCING=true
ENABLE_IMEI_TRACKING=true
# Habilita el job diario de pronósticos (APScheduler)
ENABLE_FORECAST_SCHEDULER=false

# Segundos que se mantiene en caché la respuesta de /api/ai/business-insights
BUSINESS_INSIGHTS_CACHE_SECONDS=300

# ==================================================
# MANTENIMIENTO
# ==================================================
# Modo mantenimiento (deshabilita API temporalmente)
MAINTENANCE_MODE=false

# Mensaje de mantenimiento
MAINTENANCE_MESSAGE=El sistema está en mantenimiento. Volveremos pronto.
