# Backend configuration example
# Copy to backend/.env and customize for your deployment

# Environment
ENVIRONMENT=production
DEBUG=false

# Database (required; PostgreSQL only)
DATABASE_URL=postgresql+psycopg2://user:pass@host:5432/inventory

# API Server
API_HOST=0.0.0.0
API_PORT=8000

# CORS (comma-separated origins; do not use '*' in production)
CORS_ORIGINS=https://tu-dominio.com,https://admin.tu-dominio.com
ALLOWED_HOSTS=api.tu-dominio.com

# JWT Authentication
# Generate with: openssl rand -hex 32
SECRET_KEY=GENERATE_WITH_OPENSSL_RAND_HEX_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Channel credential encryption
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CHANNEL_ENCRYPTION_KEY=GENERATE_WITH_FERNET

# Rate limiting (opcional, aplica en producción)
RATE_LIMIT_PER_MINUTE=120
LOGIN_ATTEMPTS_LIMIT=5
LOGIN_BLOCK_TIME=15

# For local development only:
# ENVIRONMENT=development
# CORS_ORIGINS=*  # Only use this locally during development

# AI / Business Insights (opcional)
ENABLE_AI_FEATURES=true
OPENAI_API_KEY=sk-tu-clave-openai
OPENAI_MODEL=gpt-4o
BUSINESS_INSIGHTS_CACHE_SECONDS=300

# --- Notificaciones y Canales ---

# SMTP Configuration (Notificaciones de sistema)
SMTP_HOST=smtp.ejemplo.com
SMTP_PORT=587
SMTP_USER=tu_usuario
SMTP_PASSWORD=tu_password
SMTP_FROM=notificaciones@tu-dominio.com
SMTP_TLS=true

# Meta / WhatsApp API Credentials (Opcional si usas Channel Integrations en UI)
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
META_PAGE_ACCESS_TOKEN=
