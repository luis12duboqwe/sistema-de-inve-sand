# Database Configuration
DATABASE_URL=sqlite:///./inventory.db

# API Server Configuration
API_HOST=0.0.0.0
API_PORT=8000

# CORS Configuration (Security)
# IMPORTANT: In production, replace with specific origins separated by commas
# Example for production: CORS_ORIGINS=["https://yourdomain.com","https://www.yourdomain.com"]
# For development (allows all): CORS_ORIGINS=["*"]
CORS_ORIGINS=["*"]

# JWT Authentication
# IMPORTANT: Change SECRET_KEY in production! Generate with: openssl rand -hex 32
SECRET_KEY=your-secret-key-change-this-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Environment
ENVIRONMENT=development
