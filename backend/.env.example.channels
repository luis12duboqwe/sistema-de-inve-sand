# =========================
# Canales automáticos (Meta)
# =========================

# 1) Verificación webhook (usa uno global o por canal)
META_VERIFY_TOKEN=pon_aqui_un_token_largo_y_unico
WHATSAPP_VERIFY_TOKEN=
MESSENGER_VERIFY_TOKEN=
INSTAGRAM_VERIFY_TOKEN=

# 2) Seguridad firma webhook (recomendado)
META_APP_SECRET=

# 3) Credenciales de envío saliente
# WhatsApp Cloud API
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Messenger + Instagram (Graph API)
META_PAGE_ACCESS_TOKEN=

# 4) Perfil IA por defecto para responder
CHANNEL_DEFAULT_SALES_PROFILE_SLUG=bot-principal
WHATSAPP_DEFAULT_SALES_PROFILE_SLUG=
MESSENGER_DEFAULT_SALES_PROFILE_SLUG=
INSTAGRAM_DEFAULT_SALES_PROFILE_SLUG=

# 5) Deduplicación de mensajes (segundos)
CHANNEL_MESSAGE_TTL_SECONDS=600

# 6) Token de servicio para endpoints IA (opcional, recomendado)
N8N_AUTH_TOKEN=