# Copy this file to deploy/.env.prod, or run ./deploy/prepare-prod-env.sh.
# Do not commit deploy/.env.prod. It is ignored by git.

# === Public entrypoint ===
# The frontend nginx container is the only service exposed publicly.
FRONTEND_PORT=80

# === Database (PostgreSQL) ===
POSTGRES_DB=inventory
POSTGRES_USER=inventory_admin
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# SQLAlchemy DSN used by the FastAPI app (keep host as 'db' for the internal network)
DATABASE_URL=postgresql+psycopg2://inventory_admin:CHANGE_ME_STRONG_PASSWORD@db:5432/inventory

# === Backend security / API ===
ENVIRONMENT=production
DEBUG=false
SECRET_KEY=GENERATE_WITH_OPENSSL_RAND_HEX_32
CHANNEL_ENCRYPTION_KEY=GENERATE_WITH_FERNET_GENERATE_KEY
ALLOWED_HOSTS=api.midominio.com,localhost,127.0.0.1
CORS_ORIGINS=https://api.midominio.com
ACCESS_TOKEN_EXPIRE_MINUTES=60
RATE_LIMIT_PER_MINUTE=120
LOGIN_ATTEMPTS_LIMIT=5
LOGIN_BLOCK_TIME=15
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# === Logging & backups ===
LOG_LEVEL=INFO
LOG_STRUCTURED=true
LOG_TO_FILES=true
LOG_DIRECTORY=/app/logs
LOG_INCLUDE_CONSOLE=true
ENABLE_AUTO_BACKUP=true
BACKUP_DIR=/app/backups
BACKUP_SCHEDULE=daily
BACKUP_RETENTION_DAYS=30
BACKUP_INTERVAL_SECONDS=86400

# === Feature flags / AI ===
ENABLE_AI_FEATURES=true
ENABLE_FORECAST_SCHEDULER=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
BUSINESS_INSIGHTS_CACHE_SECONDS=900

# === Monitoring / Alerts ===
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.0
NEW_RELIC_LICENSE_KEY=
N8N_WEBHOOK_URL=
N8N_AUTH_TOKEN=

# === Email (optional) ===
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TLS=true

# === Frontend build (Vite) ===
VITE_API_BASE_URL=/api
